{
  "permissions": {
    "allow": [
      "Bash(xargs kill *)",
      "Bash(kill 8349)",
      "Bash(kill 8541)",
      "Bash(kill 8628)",
      "Bash(echo \"exit:$?\")",
      "Bash(LOCALES=uz node --env-file=.env.local scripts/seed-exercise-translations.mjs)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if (git branch --show-current) -ne 'main' { exit 0 } else { Write-Error 'Cannot edit on main branch'; exit 2 }"
          }
        ]
      }
    ]
  }
}
